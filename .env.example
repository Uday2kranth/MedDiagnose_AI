# ═══════════════════════════════════════════════════
# MedDiagnose AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.
# ═══════════════════════════════════════════════════

# ── Google Gemini API Key ──
# Used as the server-side fallback when the user does not supply their own key.
GOOGLE_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# ── Optional Fallback LLM API Keys (Server-side) ──
# If these are configured on the server, users do not need to provide their own
# keys in the frontend chat settings (⚙️ gear icon).
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY_HERE"
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY_HERE"
CEREBRAS_API_KEY="YOUR_CEREBRAS_API_KEY_HERE"

# ── Gmail API — Stateless Server Auth ──
# Paste the RAW JSON contents of your local token.json here as a single line.
# This allows the server to send emails via Gmail API without uploading any files.
# To get this value: open token.json → copy the entire JSON string → paste below.
# Used on Render/Koyeb. For local dev, token.json file is used instead.
GMAIL_TOKEN_JSON='{"token":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.send"]}'

# ── Frontend Build Variable (Vercel) ──
# Set this in Vercel's Environment Variables panel, NOT in this file.
# The frontend reads this at build time to know where the backend lives.
# Example: https://meddiagnose-ai.onrender.com/api
VITE_API_URL="https://your-backend.onrender.com/api"
